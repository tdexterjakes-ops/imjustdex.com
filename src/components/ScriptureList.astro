---
// Article-specific scripture reference list (currently only used in job/index.html).
// Wraps children in .scripture-list. Expect .scripture-item > .scripture-ref + .scripture-note.
// Carries its own scoped styles so articles that don't use it don't pay the CSS cost.
---
<div class="scripture-list">
  <slot />
</div>

<style>
  /* ── Scripture reference list ── */
  .scripture-list {
    margin: 24px 0 36px;
  }
  .scripture-list :global(.scripture-item) {
    display: flex; gap: 14px;
    padding: 12px 0;
    border-bottom: 1px solid var(--body-faint);
  }
  .scripture-list :global(.scripture-item:first-child) {
    border-top: 1px solid var(--body-faint);
  }
  .scripture-list :global(.scripture-ref) {
    font-family: var(--mono);
    font-size: .75rem; letter-spacing: .1em;
    text-transform: uppercase; font-weight: 700;
    color: var(--accent);
    white-space: nowrap;
    min-width: 140px;
  }
  .scripture-list :global(.scripture-note) {
    font-family: var(--body);
    font-size: .92rem;
    line-height: 1.5;
    color: var(--body-muted);
  }

  @media (max-width: 760px) {
    .scripture-list :global(.scripture-item) { flex-direction: column; gap: 4px; }
    .scripture-list :global(.scripture-ref) { min-width: 0; }
  }
</style>
