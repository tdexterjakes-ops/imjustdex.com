---
import type { CollectionEntry } from 'astro:content';
import type { PlateVariant, PlateImage } from '~/content/config';

// Layout sizes the archive cascade can hand a plate. These are LAYOUT-only
// (grid-column spans), distinct from the schema PlateVariant which carries
// typographic intent. 'row' = full 12 cols, 'half' = 6 cols.
type ForcedLayout = 'wide' | 'secondary' | 'banner' | 'row' | 'half';

// Cover textures the archive cascade can hand a plate. Superset of the
// schema PlateImage (adds 'lines') — the cascade can assign textures the
// frontmatter enum doesn't expose, since alternation is computed, not authored.
type ImageCover = PlateImage | 'lines';

interface Props {
  entry: CollectionEntry<'words'>;
  // Position-derived defaults if frontmatter doesn't specify.
  positionVariant?: PlateVariant;
  // Cascade-computed layout that fills its row regardless of frontmatter.
  // Wins over frontmatter so a plate moving from lead → archive can't drag
  // .plate-lead (span 12 + lead-only inner grammar) into a normal row.
  forcedLayout?: ForcedLayout;
  // Cascade-computed cover that enforces the Texture Alternation Rule
  // (DESIGN-SYSTEM §6) across the whole archive reading order. When the
  // caller controls covers it ALWAYS passes this: a texture name to force a
  // cover, or `null` to force plain (overriding frontmatter). `undefined`
  // means "not controlled" → fall back to frontmatter.
  forcedImage?: ImageCover | null;
  hidden?: boolean;
}
const { entry, positionVariant, forcedLayout, forcedImage, hidden = false } = Astro.props;
const d = entry.data;

// Variant resolution: forced layout > frontmatter > position fallback > 'wide'.
// 'row' is encoded as wide-typography + plate-row modifier so the typography
// stack stays unified (no separate row-only typography ramp).
const layout: ForcedLayout | PlateVariant =
  forcedLayout ?? d.plate.variant ?? positionVariant ?? 'wide';
// Cover resolution: caller-controlled cascade wins. `undefined` = not
// controlled (use frontmatter); `null` = controlled-plain; texture = forced.
const image: ImageCover | undefined =
  forcedImage === undefined ? d.plate.image : (forcedImage ?? undefined);
const explicitRow = d.plate.row || layout === 'row';

// Class mapping. 'row' decomposes to (wide + plate-row). Everything else is
// .plate-{layout}, with 'lead' tolerated on the off-chance frontmatter still
// asks for it AND no forcedLayout overrides — but archive callers always
// pass forcedLayout, so this branch is dead in practice.
const baseVariantClass = layout === 'row' ? 'plate-wide' : `plate-${layout}`;
const classes = ['plate', baseVariantClass];
if (image) {
  classes.push('plate-image', `img-${image}`);
}
if (explicitRow) {
  classes.push('plate-row');
}
const cls = classes.join(' ');

// Inverse modifier on title: production uses .inverse on plate-image variants for contrast.
// 'med' typography on banner-class plates AND on row-spanning fills (so a 12-col
// row plate doesn't shrink its title to feature/wide proportions when given more
// horizontal space).
const titleCls = ['plate-title'];
if (layout === 'banner' || layout === 'row' || image) {
  titleCls.push('med');
}
if (image) {
  titleCls.push('inverse');
}

const dateOnly = d.publishedDate.slice(0, 10);
const dateLabel = new Date(dateOnly + 'T00:00:00Z').toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  timeZone: 'UTC',
});
const primaryLane = d.lanes[0];
const laneList = d.lanes.map((l) => l.toLowerCase()).join(' ');
---
<article {...(hidden ? { class: 'earlier-more', hidden: true } : {})}>
  <a class={cls} href={`/words/${entry.slug}/`} aria-label={`Read: ${d.title}`} data-lane={laneList}>
    <span class="plate-lane">{primaryLane}</span>
    <div class="plate-body">
      <h2 class={titleCls.join(' ')}>{d.title}</h2>
      <p class="plate-deck">{d.deck}</p>
    </div>
    <div class="meta-rail">
      <time datetime={dateOnly}>{dateLabel}</time>
      <span class="dot" aria-hidden="true">·</span>
      <span>{d.readTime}</span>
    </div>
  </a>
</article>
