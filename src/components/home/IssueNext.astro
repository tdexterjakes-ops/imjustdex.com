---
import type { CollectionEntry } from 'astro:content';

interface Props {
  next: CollectionEntry<'words'>;
}
const { next } = Astro.props;
const d = next.data;
const dateOnly = d.publishedDate.slice(0, 10);
const dateLabel = new Date(dateOnly + 'T00:00:00Z').toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  timeZone: 'UTC',
});
const meta = `${d.lanes[0]} · ${dateLabel} · ${d.readTime}`;
---
<a class="issue-next" href="#subscribe-manifesto" aria-label={`Scroll to subscribe and be notified when ${d.title} is published`}>
  <span class="next-tag">Next</span>
  <span class="next-title">{d.title}</span>
  <span class="next-meta">{meta}</span>
  <span class="next-cta" aria-hidden="true">Notify me →</span>
</a>
