---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'words'>;
}

const { entry } = Astro.props;
const d = entry.data;
const slug = entry.slug;

const articleUrl = `https://imjustdex.com/words/${slug}/`;
const ogImageUrl = `https://imjustdex.com/img/og-${slug}.png?v=${d.ogImagePhase}`;
const titleSuffix = ' — DX';
const pageTitle = `${d.title} — Coming Soon — DX`;

const dateOnly = d.publishedDate.slice(0, 10);
const publishDateLong = new Date(dateOnly + 'T00:00:00Z').toLocaleDateString('en-US', {
  weekday: 'long',
  month: 'long',
  day: 'numeric',
  year: 'numeric',
  timeZone: 'UTC',
});
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="color-scheme" content="light dark">
  <meta name="robots" content="noindex">

  <title>{pageTitle}</title>
  <meta name="description" content={`${d.description} Publishing ${publishDateLong}.`}>

  <link rel="canonical" href={articleUrl}>
  <link rel="icon" type="image/png" sizes="32x32" href="/img/favicon-32.png">
  <link rel="apple-touch-icon" href="/img/apple-touch-icon.png">

  <!-- Open Graph (preserve so social previews still work) -->
  <meta property="og:title" content={d.title}>
  <meta property="og:description" content={`${d.description} Publishing ${publishDateLong}.`}>
  <meta property="og:image" content={ogImageUrl}>
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content={d.ogImageAlt}>
  <meta property="og:url" content={articleUrl}>
  <meta property="og:type" content="article">
  <meta property="og:site_name" content="DX">
  <meta property="article:author" content="Dexter Jakes">

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={d.title}>
  <meta name="twitter:description" content={`${d.description} Publishing ${publishDateLong}.`}>
  <meta name="twitter:image" content={ogImageUrl}>

  <!-- Self-hosted font preloads -->
  <link rel="preload" as="font" type="font/woff2" href="/fonts/Anton-Regular.woff2" crossorigin>
  <link rel="preload" as="font" type="font/woff2" href="/fonts/IBMPlexSans-Regular.woff2" crossorigin>
  <link rel="preload" as="font" type="font/woff2" href="/fonts/IBMPlexSans-Bold.woff2" crossorigin>

  <!-- Styles -->
  <link rel="stylesheet" href="/css/tokens.css?v=phase23">
  <link rel="stylesheet" href="/css/shell.css?v=phase23">
  <link rel="stylesheet" href="/css/article.css?v=phase24">

  <!-- Mode: synchronous in <head> for FOUC prevention -->
  <script src="/js/mode.js?v=phase11" is:inline></script>
</head>
<body>
  <a href="#article" class="skip-link">Skip to article</a>
  <div class="ruler-top" aria-hidden="true"></div>
  <div class="ruler-left" aria-hidden="true"></div>

  <div class="page-shell">
    <header>
      <nav class="masthead" aria-label="Main navigation">
        <a class="brand-block" href="/" aria-label="DX home">
          <span class="brand-mark">
            <img src="/img/logo-dark.svg" alt="" class="brand-logo" width="41" height="28" data-base="/img/">
          </span>
          <span class="brand-word">Words</span>
        </a>
        <button class="mode-toggle" id="modeToggle" type="button" aria-label="Toggle editorial mode" aria-pressed="false">
          Mode: Light
        </button>
      </nav>
    </header>

    <main id="article">
      <div class="article-frame">

        <header class="article-header">
          <div class="article-eyebrow">
            <span class="article-tag" style="background:#c00;color:#f5f5f1;border-color:#c00;">Coming Soon</span>
            {[...d.lanes, ...d.tags].map((t) => <span class="article-tag">{t}</span>)}
            <span class="article-read">{d.readTime}</span>
          </div>
          <h1 class="article-title">{d.title}</h1>
          <p class="article-deck">{d.deck}</p>
        </header>

        <article class="article-body">
          <p style="font-family:'IBM Plex Sans',Helvetica,Arial,sans-serif;font-size:1.05em;line-height:1.7;margin:0 0 1.4em 0;">
            This essay publishes <strong>{publishDateLong}</strong>.
          </p>

          <p style="font-family:'IBM Plex Sans',Helvetica,Arial,sans-serif;font-size:1em;line-height:1.7;margin:0 0 2em 0;opacity:0.8;">
            Subscribe below to get it delivered the moment it goes live — or check back at the listed date.
          </p>
        </article>

        <!-- Email signup -->
        <form class="email-signup" action="/api/subscribe?u=41b4a69d61d7e6d50724373f0&amp;id=216fb11473&amp;f_id=009345e0f0" method="post">
          <span class="email-signup-label">Get notified when I publish</span>
          <div class="email-signup-fields">
            <label for="email" class="sr-only">Email address</label>
            <input type="email" name="EMAIL" id="email" class="email-signup-input" placeholder="Your email" required>
            <button type="submit" class="email-signup-submit">Notify me</button>
          </div>
          <div class="email-signup-hp" aria-hidden="true">
            <input type="text" name="website" tabindex="-1" value="">
          </div>
        </form>

        <a href="/" class="article-back">&larr; Back</a>

      </div>
    </main>

    <footer class="footer-strip" aria-label="Footer">
      <div class="footer-links">
        <a href="https://instagram.com/ImJustDex" target="_blank" rel="noopener noreferrer">Instagram</a>
        <span class="footer-sep" aria-hidden="true">&middot;</span>
        <a href="https://x.com/ImJustDex" target="_blank" rel="noopener noreferrer">X</a>
        <span class="footer-sep" aria-hidden="true">&middot;</span>
        <a href="/feed.xml" aria-label="RSS feed">Feed</a>
      </div>
      <span>Built by Dex &middot; Est. 2026</span>
    </footer>
  </div>

  <script src="/js/signup.js?v=phase14" is:inline defer></script>
</body>
</html>
