---
import { getCollection, type CollectionEntry } from 'astro:content';
import ArticleLayout from '~/layouts/ArticleLayout.astro';
import ComingSoonLayout from '~/layouts/ComingSoonLayout.astro';
import { isPubliclyLive, isUpcoming } from '~/utils/visibility';

export async function getStaticPaths() {
  const entries = await getCollection('words');
  // Build static paths for both publicly-live and upcoming essays. Upcoming
  // essays render a "coming soon" placeholder so dispatch teasers and social
  // shares have a real URL to land on. Anything else (drafts, archived) is
  // excluded from the build.
  return entries
    .filter((entry) => isPubliclyLive(entry) || isUpcoming(entry))
    .map((entry) => ({
      params: { slug: entry.slug },
      props: { entry },
    }));
}

interface Props {
  entry: CollectionEntry<'words'>;
}

const { entry } = Astro.props;
const live = isPubliclyLive(entry);
const { Content } = live ? await entry.render() : { Content: null };
---
{live ? (
  <ArticleLayout entry={entry}>
    <Content />
  </ArticleLayout>
) : (
  <ComingSoonLayout entry={entry} />
)}
