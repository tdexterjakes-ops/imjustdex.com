          <!-- ═ HOME COMPONENTS ═ -->
          <header class="s-subchapter-head">
            <span class="s-subchapter-eyebrow">Home components</span>
            <p class="s-subchapter-body">The homepage's own components — rendered here on the same <code>home-augment.css</code> the live site loads.</p>
