        <!-- ─────────────────────────────────
             01 · FOUNDATIONS
        ───────────────────────────────── -->
        <section id="foundations" class="s-chapter" aria-labelledby="foundations-head">
          <header class="s-chapter-head">
            <span class="s-chapter-num">01</span>
            <h2 id="foundations-head" class="s-chapter-title">Foundations</h2>
            <p class="s-chapter-deck">The non-negotiables. Logo, color, type, grid.</p>
          </header>

          <!-- LOGO -->
          <article class="s-section" id="foundations-logo">
            <header class="s-section-head">
              <span class="s-section-num">1.1</span>
              <h3>Logo — DX monogram</h3>
            </header>
            <p>The monogram is set in False Regular, delivered as outlined SVG — no runtime font dependency. Two letters, no tagline, no lockup. Three approved colorways: dark on light, white on dark, white on accent.</p>
            <div class="s-logo-grid">
              <div class="s-logo-card s-on-light">
                <svg class="s-logo-svg" viewBox="0 0 1484.43 1027.42" aria-hidden="true">
                  <path fill="#050505" d="M134.2,846V169H0L134.2,0h331.66c63.75,0,120.84,9.27,171.28,27.8s93.41,45.94,128.91,82.19,62.73,81.38,81.7,135.36,28.45,116.42,28.45,187.33-9.69,131.12-29.05,183.09c-19.38,51.97-47.02,95.08-82.92,129.33s-79.28,59.62-130.12,76.14-108.12,24.77-171.88,24.77H134.2ZM352.2,677h95.56c26.61,0,52.22-3.62,76.81-10.88s46.38-20.16,65.33-38.7c18.94-18.55,34.06-44.36,45.36-77.42,11.28-33.06,16.94-75.39,16.94-127s-5.45-94.95-16.33-127.61c-10.89-32.66-25.61-58.45-44.16-77.41-18.56-18.94-39.94-31.84-64.12-38.7-24.19-6.84-49.59-10.28-76.2-10.28h-99.19v508Z"/>
                  <path fill="#050505" d="M456.78,0h264.77l200.7,270.72L1127.78,0h257.52l-336.11,441.12,435.25,586.3-336.11-96.72-232.12-313.12-174.09,228.42h-257.52l303.45-400.03L456.78,0Z"/>
                </svg>
                <span class="s-logo-caption">Primary · #050505 on #f4f4f1</span>
              </div>
              <div class="s-logo-card s-on-dark">
                <svg class="s-logo-svg" viewBox="0 0 1484.43 1027.42" aria-hidden="true">
                  <path fill="#f3f0e8" d="M134.2,846V169H0L134.2,0h331.66c63.75,0,120.84,9.27,171.28,27.8s93.41,45.94,128.91,82.19,62.73,81.38,81.7,135.36,28.45,116.42,28.45,187.33-9.69,131.12-29.05,183.09c-19.38,51.97-47.02,95.08-82.92,129.33s-79.28,59.62-130.12,76.14-108.12,24.77-171.88,24.77H134.2ZM352.2,677h95.56c26.61,0,52.22-3.62,76.81-10.88s46.38-20.16,65.33-38.7c18.94-18.55,34.06-44.36,45.36-77.42,11.28-33.06,16.94-75.39,16.94-127s-5.45-94.95-16.33-127.61c-10.89-32.66-25.61-58.45-44.16-77.41-18.56-18.94-39.94-31.84-64.12-38.7-24.19-6.84-49.59-10.28-76.2-10.28h-99.19v508Z"/>
                  <path fill="#f3f0e8" d="M456.78,0h264.77l200.7,270.72L1127.78,0h257.52l-336.11,441.12,435.25,586.3-336.11-96.72-232.12-313.12-174.09,228.42h-257.52l303.45-400.03L456.78,0Z"/>
                </svg>
                <span class="s-logo-caption">Inverse · #f3f0e8 on #060606</span>
              </div>
              <div class="s-logo-card s-on-accent">
                <svg class="s-logo-svg" viewBox="0 0 1484.43 1027.42" aria-hidden="true">
                  <path fill="#fff" d="M134.2,846V169H0L134.2,0h331.66c63.75,0,120.84,9.27,171.28,27.8s93.41,45.94,128.91,82.19,62.73,81.38,81.7,135.36,28.45,116.42,28.45,187.33-9.69,131.12-29.05,183.09c-19.38,51.97-47.02,95.08-82.92,129.33s-79.28,59.62-130.12,76.14-108.12,24.77-171.88,24.77H134.2ZM352.2,677h95.56c26.61,0,52.22-3.62,76.81-10.88s46.38-20.16,65.33-38.7c18.94-18.55,34.06-44.36,45.36-77.42,11.28-33.06,16.94-75.39,16.94-127s-5.45-94.95-16.33-127.61c-10.89-32.66-25.61-58.45-44.16-77.41-18.56-18.94-39.94-31.84-64.12-38.7-24.19-6.84-49.59-10.28-76.2-10.28h-99.19v508Z"/>
                  <path fill="#fff" d="M456.78,0h264.77l200.7,270.72L1127.78,0h257.52l-336.11,441.12,435.25,586.3-336.11-96.72-232.12-313.12-174.09,228.42h-257.52l303.45-400.03L456.78,0Z"/>
                </svg>
