---
import { getCollection, type CollectionEntry } from 'astro:content';
import HomeLayout from '~/layouts/HomeLayout.astro';
import LatestBar from '~/components/home/LatestBar.astro';
import IdentityHero from '~/components/home/IdentityHero.astro';
import LaneIndex from '~/components/home/LaneIndex.astro';
import RowHead from '~/components/home/RowHead.astro';
import LeadPlate from '~/components/home/LeadPlate.astro';
import Plate from '~/components/home/Plate.astro';
import IssueNext from '~/components/home/IssueNext.astro';
import SubscribeManifesto from '~/components/home/SubscribeManifesto.astro';
import type { Lane, PlateVariant } from '~/content/config';
import { isPubliclyLive, isUpcoming } from '~/utils/visibility';

// Build-time date drives published vs. upcoming partition.
const now = new Date();

// Sort everything by publishedDate desc.
const all = (await getCollection('words')).sort(
  (a, b) =>
    new Date(b.data.publishedDate).getTime() - new Date(a.data.publishedDate).getTime()
);

const published = all.filter((e) => isPubliclyLive(e, now));
const upcoming = all.filter((e) => isUpcoming(e, now));

// Lead = newest published.
const lead = published[0];
if (!lead) throw new Error('No published essays — cannot render homepage.');

const leadDate = new Date(lead.data.publishedDate);
const leadYear = leadDate.getUTCFullYear();
const leadMonth = leadDate.getUTCMonth();

// "This Month" = same calendar month as lead, excluding lead.
const rest = published.slice(1);
const thisMonth = rest.filter((e) => {
  const d = new Date(e.data.publishedDate);
  return d.getUTCFullYear() === leadYear && d.getUTCMonth() === leadMonth;
});

// "Earlier" = anything older than lead's month.
const earlier = rest.filter((e) => {
  const d = new Date(e.data.publishedDate);
  return d.getUTCFullYear() !== leadYear || d.getUTCMonth() !== leadMonth;
});
const EARLIER_VISIBLE = 6;
const earlierVisible = earlier.slice(0, EARLIER_VISIBLE);
const earlierMore = earlier.slice(EARLIER_VISIBLE);

// Issue next = first upcoming essay (sorted asc by date).
const issueNext = upcoming
  .slice()
  .sort(
    (a, b) =>
      new Date(a.data.publishedDate).getTime() - new Date(b.data.publishedDate).getTime()
  )[0];

// Lane counts: published essays only, multi-lane articles count for each lane.
const laneCounts: Record<Lane, number> = {
  Faith: published.filter((e) => e.data.lanes.includes('Faith')).length,
  Identity: published.filter((e) => e.data.lanes.includes('Identity')).length,
  Art: published.filter((e) => e.data.lanes.includes('Art')).length,
};

// Issue head: derive entry number + week label from lead.
// Entry number = chronological position of lead among all published essays (zero-padded).
const entryNo = String(published.length).padStart(2, '0');
const weekLabel = `Week of ${leadDate.toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
  timeZone: 'UTC',
})}`;
const issueNo = `Entry No. ${entryNo}`;

// Positional plate variant fallback: alternate wide → secondary → banner.
const PLATE_ROTATION: PlateVariant[] = ['wide', 'secondary', 'banner'];
const positionalVariant = (i: number): PlateVariant => PLATE_ROTATION[i % PLATE_ROTATION.length];

// Row-packer: returns a per-plate layout sequence that fills every row of
// the 12-col grid exactly. The base rotation wide(5) + secondary(3) +
// banner(4) sums to 12, so any multiple-of-3 segment tiles cleanly.
// Partial trailing segments are resized:
//   • 1 leftover → single 'row' plate spanning all 12 cols
//   • 2 leftover → two 'half' plates splitting 6 + 6
//
// Editor-authored full-row plates (frontmatter `plate.row: true`) are
// honored: they always span 12 cols on their own row, and the surrounding
// plates are packed into their own clean segments around them — so a
// row break in the middle of the cascade can't strand a partial row
// before or after it.
//
// This wins over per-article frontmatter `plate.variant` for archive
// surfaces, which is intentional: a former-lead essay (e.g. gloria with
// variant=lead) cannot drag .plate-lead's full-row + lead-only inner
// grammar into a normal archive row.
type ForcedLayout = 'wide' | 'secondary' | 'banner' | 'row' | 'half';

function packSegment(count: number): ForcedLayout[] {
  const out: ForcedLayout[] = [];
  const fullRows = Math.floor(count / 3);
  for (let i = 0; i < fullRows * 3; i++) {
    out.push(PLATE_ROTATION[i % 3] as ForcedLayout);
  }
  const remainder = count - fullRows * 3;
  if (remainder === 1) out.push('row');
  else if (remainder === 2) out.push('half', 'half');
  return out;
}

function packCascade(plates: CollectionEntry<'words'>[]): ForcedLayout[] {
  const out: ForcedLayout[] = new Array(plates.length);
  let segment: number[] = [];
  const flush = () => {
    const layouts = packSegment(segment.length);
    segment.forEach((srcIdx, segIdx) => {
      out[srcIdx] = layouts[segIdx];
    });
    segment = [];
  };
  plates.forEach((p, i) => {
    if (p.data.plate.row) {
      flush();
      out[i] = 'row';
    } else {
      segment.push(i);
    }
  });
  flush();
  return out;
}
---
<HomeLayout>
  <LatestBar issueNo={issueNo} weekLabel={weekLabel} latest={lead} />

  <IdentityHero />

  <LaneIndex counts={laneCounts} />

  <main id="archive">
    <section class="plates" aria-label="Essay archive">
      <RowHead num="01" label="This Week" variant="lead" />
      <LeadPlate entry={lead} />

      {thisMonth.length > 0 && (
        <>
          <RowHead num="02" label="This Month" />
          {(() => {
            const layouts = packCascade(thisMonth);
            return thisMonth.map((entry, i) => (
              <Plate entry={entry} forcedLayout={layouts[i]} />
            ));
          })()}
        </>
      )}

      {earlierVisible.length > 0 && (
        <>
          <RowHead num={thisMonth.length > 0 ? '03' : '02'} label="Earlier" />
          {(() => {
            // Pack visible + hidden together so the layout stays balanced
            // when "View More" expands the section in-place.
            const layouts = packCascade(earlier);
            return [
              ...earlierVisible.map((entry, i) => (
                <Plate entry={entry} forcedLayout={layouts[i]} />
              )),
              ...earlierMore.map((entry, i) => (
                <Plate entry={entry} forcedLayout={layouts[EARLIER_VISIBLE + i]} hidden />
              )),
            ];
          })()}
          {earlierMore.length > 0 && (
            <div class="earlier-more-wrap">
              <button class="earlier-more-btn" type="button" data-earlier-toggle aria-expanded="false">
                <span class="btn-label">View Earlier Essays</span>
                <span class="btn-count" data-earlier-count>{`— ${earlierMore.length} more`}</span>
                <span class="btn-glyph" aria-hidden="true">↓</span>
              </button>
            </div>
          )}
        </>
      )}
    </section>
  </main>

  {issueNext && <IssueNext next={issueNext} />}

  <SubscribeManifesto />
</HomeLayout>
